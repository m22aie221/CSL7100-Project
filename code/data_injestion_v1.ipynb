    "user_embeddings = embeddings.filter(col(\"id\") <= max_user_id) \\\n",
    "    .withColumnRenamed(\"id\", \"user_id\")\n",
    "\n",
    "item_embeddings = embeddings.filter(col(\"id\") > max_user_id) \\\n",
    "    .withColumn(\n",
    "        \"item_id\", col(\"id\") - (max_user_id + 1)\n",
    "    ).select(\"item_id\", \"embedding\")"
