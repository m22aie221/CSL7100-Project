   "id": "c32274a9-c911-4e8e-8846-ee42a8a492da",
   "metadata": {},
   "outputs": [],
   "source": [
    "import builtins\n",
    "from pyspark.sql.functions import udf\n",
    "from pyspark.sql.types import DoubleType\n",
    "\n",
    "def dot_product(v1, v2):\n",
    "    if v1 is None or v2 is None:\n",
    "        return 0.0\n",
    "    return float(builtins.sum(a*b for a,b in zip(v1, v2)))\n",
    "\n",
    "dot_udf = udf(dot_product, DoubleType())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 87,
   "id": "1195b204-0b53-4c48-8029-f6fd3f742ed1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Candidate Filtering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 88,
   "id": "3fe19e41-3333-4459-89ef-c261479d093b",
   "metadata": {},
   "outputs": [],
   "source": [
    "top_items = train_df.groupBy(\"item_id\").count() \\\n",
    "    .orderBy(col(\"count\").desc()) \\\n",
    "    .limit(8000) \\\n",
    "    .select(\"item_id\")\n",
    "\n",
    "candidate_items = item_embeddings.join(top_items, \"item_id\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 89,
   "id": "29fba3e8-dd2c-4a32-813c-1c2e8dc10968",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate Recommendations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 125,
   "id": "02747ab7-0192-432f-986a-c1906343bc7b",
   "metadata": {},
   "outputs": [],
   "source": [
    "## Candidate Scoring\n",
    "recs = user_embeddings.alias(\"u\") \\\n",
    "    .crossJoin(candidate_items.alias(\"i\")) \\\n",
    "    .withColumn(\n",
    "        \"score\",\n",
    "        dot_udf(col(\"u.embedding\"), col(\"i.embedding\"))\n",
    "    ).select(\n",
    "        col(\"u.user_id\"),\n",
    "        col(\"i.item_id\"),\n",
    "        col(\"score\")\n",
    "    )\n",
    "#  REMOVE SEEN ITEMS\n",
    "seen_items = train_df.select(\"user_id\", \"item_id\").distinct()\n",
    "\n",
    "recs = recs.join(\n",
    "    seen_items,\n",
    "    [\"user_id\", \"item_id\"],\n",
    "    \"left_anti\"\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 126,
   "id": "5af5ab60-209b-4e2a-b54b-6e02b523a11b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top-K per User"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 127,
   "id": "300c211d-53dc-4dd9-a0de-9405b1363895",
   "metadata": {},
   "outputs": [],
   "source": [
    "K = 5\n",
    "\n",
    "window = Window.partitionBy(\"user_id\").orderBy(col(\"score\").desc())\n",
    "\n",
    "recommendations = recs.withColumn(\n",
    "    \"rnk\", row_number().over(window)\n",
    ").filter(col(\"rnk\") <= K).drop(\"rnk\")"
   ]
  },
