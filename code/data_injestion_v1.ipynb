    "exploded = explode_map(ranks)\n",
    "\n",
    "recommendations = exploded.select(\n",
    "    col(\"user_id\"),\n",
    "    col(\"id\").alias(\"item_id\"),\n",
    "    col(\"score\").alias(\"rank\")\n",
    ")"
   ]
  },
