  {
   "cell_type": "code",
   "execution_count": 53,
   "id": "ee73f04d-6719-4767-8b18-3d08a3441438",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import col, count\n",
    "from pyspark.sql.functions import max as spark_max\n",
    "from pyspark.sql.functions import min as spark_min\n",
    "from pyspark.sql.window import Window\n",
    "from pyspark.ml.feature import VectorAssembler\n",
    "from pyspark.sql.functions import collect_list\n",
    "from pyspark.ml.linalg import Vectors, VectorUDT\n",
    "from pyspark.sql.functions import udf\n",
    "from pyspark.sql.types import DoubleType\n",
    "import builtins"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 54,
   "id": "79268419-eb75-45ad-94a4-6fdb771322ef",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Hybrid model (PPR + Content) using: popularity + recency features \n",
    "# normalization\n",
    "# DOT PRODUCT\n",
    "# weighted user profile"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 55,
   "id": "add6b9a3-61ff-40dc-83a5-578f4566f297",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🔹 Step 1: Build Item Features (Popularity + Recency)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 56,
   "id": "9d83fe62-480a-47a4-8c37-8337bc273833",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                "
     ]
    }
   ],
   "source": [
    "# --- Popularity ---\n",
    "item_popularity = train_df.groupBy(\"item_id\").agg(\n",
    "    count(\"*\").alias(\"popularity\")\n",
    ")\n",
    "\n",
    "max_pop = item_popularity.agg(spark_max(\"popularity\")).collect()[0][0]\n",
    "\n",
    "item_popularity = item_popularity.withColumn(\n",
    "    \"popularity\",\n",
    "    col(\"popularity\") / max_pop\n",
    ")\n",
    "\n",
    "# --- Recency ---\n",
    "max_time = train_df.agg(spark_max(\"unixReviewTime\")).collect()[0][0]\n",
    "\n",
    "item_recency = train_df.withColumn(\n",
    "    \"recency\",\n",
    "    col(\"unixReviewTime\") / max_time\n",
    ").select(\"item_id\", \"recency\").dropDuplicates([\"item_id\"])\n",
    "\n",
    "# --- Combine ---\n",
    "item_features = item_popularity.join(item_recency, \"item_id\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 57,
   "id": "2fff13a1-87df-48b2-94e9-14bc0be74db6",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Normalize"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 58,
   "id": "ff8fd2be-2e33-4c54-8923-792839d77381",
   "metadata": {},
   "outputs": [],
   "source": [
    "w = Window.partitionBy()\n",
    "\n",
    "item_features = item_features \\\n",
    "    .withColumn(\"pop_norm\",\n",
    "        (col(\"popularity\") - spark_min(\"popularity\").over(w)) /\n",
    "        (spark_max(\"popularity\").over(w) - spark_min(\"popularity\").over(w) + 1e-9)\n",
    "    ) \\\n",
    "    .withColumn(\"rec_norm\",\n",
    "        (col(\"recency\") - spark_min(\"recency\").over(w)) /\n",
    "        (spark_max(\"recency\").over(w) - spark_min(\"recency\").over(w) + 1e-9)\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 59,
   "id": "103f184c-8a6b-47ac-ba8a-33c76ea27f6c",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Step 3: Convert to Vector"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "866d9d43-078f-4649-b367-2cf868314d36",
   "metadata": {},
   "outputs": [],
   "source": [
    "assembler = VectorAssembler(\n",
    "    inputCols=[\"pop_norm\", \"rec_norm\"],\n",
    "    outputCol=\"features\"\n",
    ")\n",
    "\n",
    "item_features = assembler.transform(item_features).select(\"item_id\", \"features\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "36564f18-1ac7-48e2-a4cb-6664fecc9ecc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 4: Build USER PROFILE (Weighted)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "b008ea99-1d57-466b-81a9-203c22c0bfe5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def weighted_avg(vectors, ratings):\n",
    "    if not vectors:\n",
    "        return None\n",
    "\n",
    "    vectors = [list(v) for v in vectors]\n",
    "    total = builtins.sum(ratings)\n",
    "\n",
    "    dim = len(vectors[0])\n",
    "    avg = [0.0] * dim\n",
    "\n",
    "    for v, r in zip(vectors, ratings):\n",
    "        for i in range(dim):\n",
    "            avg[i] += v[i] * r\n",
    "\n",
    "    return Vectors.dense([x / total for x in avg])\n",
    "\n",
    "weighted_avg_udf = udf(weighted_avg, VectorUDT())\n",
    "\n",
    "user_profiles = train_df.join(item_features, \"item_id\") \\\n",
    "    .groupBy(\"user_id\") \\\n",
    "    .agg(\n",
    "        collect_list(\"features\").alias(\"feat_list\"),\n",
    "        collect_list(\"overall\").alias(\"rating_list\")\n",
    "    ) \\\n",
    "    .withColumn(\"user_vec\", weighted_avg_udf(\"feat_list\", \"rating_list\")) \\\n",
    "    .select(\"user_id\", \"user_vec\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "96edac37-2f4b-4de5-a9f3-ac401b3c475d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Step 5: DOT PRODUCT (FIXED SIMILARITY)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "id": "ed0d64fe-22c6-40a4-9576-787a0dfa3f9e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def dot_product(v1, v2):\n",
    "    if v1 is None or v2 is None:\n",
    "        return 0.0\n",
    "\n",
    "    v1 = list(v1)\n",
    "    v2 = list(v2)\n",
    "\n",
    "    return float(builtins.sum(a*b for a,b in zip(v1, v2)))\n",
    "\n",
    "dot_udf = udf(dot_product, DoubleType())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 65,
   "id": "02b3bd78-26e6-4415-82ca-1cb1be351329",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 6: Compute Content Score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "id": "56a3a9f9-07ac-4349-a466-29b522a02428",
   "metadata": {},
   "outputs": [],
   "source": [
    "content_scores = recommendations.join(user_profiles, \"user_id\") \\\n",
    "    .join(item_features, \"item_id\") \\\n",
    "    .withColumn(\n",
    "        \"content_score\",\n",
    "        dot_udf(col(\"user_vec\"), col(\"features\"))\n",
    "    ).select(\"user_id\", \"item_id\", \"content_score\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "6fff10e4-03cb-468f-9c21-21e42d2399b6",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Step 7: Normalize Scores"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 68,
   "id": "bc13aef7-8117-45f2-94fb-0b05984a8923",
   "metadata": {},
   "outputs": [],
   "source": [
    "w = Window.partitionBy(\"user_id\")\n",
    "\n",
    "# PPR normalization\n",
    "ppr_norm = recommendations.withColumn(\n",
    "    \"ppr_norm\",\n",
    "    (col(\"rank\") - spark_min(\"rank\").over(w)) /\n",
    "    (spark_max(\"rank\").over(w) - spark_min(\"rank\").over(w) + 1e-9)\n",
    ")\n",
    "\n",
    "# Content normalization\n",
    "content_norm = content_scores.withColumn(\n",
    "    \"content_norm\",\n",
    "    (col(\"content_score\") - spark_min(\"content_score\").over(w)) /\n",
    "    (spark_max(\"content_score\").over(w) - spark_min(\"content_score\").over(w) + 1e-9)\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 69,
   "id": "3c443b84-338c-4f09-8df5-f274d09142ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🔹 Step 8: Combine (Hybrid Score)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 70,
   "id": "b6e86805-3f9f-43f0-880c-c8e563d52241",
   "metadata": {},
   "outputs": [],
   "source": [
    "hybrid = ppr_norm.join(content_norm, [\"user_id\", \"item_id\"])\n",
    "\n",
    "w1 = 0.7\n",
    "w2 = 0.3\n",
    "\n",
    "hybrid = hybrid.withColumn(\n",
    "    \"final_score\",\n",
    "    w1 * col(\"ppr_norm\") + w2 * col(\"content_norm\")\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 71,
   "id": "85c908e0-dbb6-46fd-80de-b5d7ef274795",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🔹 Step 9: Top-K Recommendations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 72,
   "id": "7993bc3b-93f8-4bcb-bdd3-0c88874be524",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import row_number\n",
    "\n",
    "K = 5\n",
    "\n",
    "window = Window.partitionBy(\"user_id\").orderBy(col(\"final_score\").desc())\n",
    "\n",
    "hybrid_recommendations = hybrid.withColumn(\n",
    "    \"rnk\", row_number().over(window)\n",
    ").filter(col(\"rnk\") <= K).select(\n",
    "    \"user_id\", \"item_id\", col(\"final_score\").alias(\"rank\")\n",
    ")"
   ]
  },
